# Copie para .env e preencha. O docker-compose injeta isto no bot E no lavalink.

# ===== Lavalink (self-host) =====
# Invente uma senha; precisa ser a MESMA no application.yml (já usa esta var).
LAVALINK_PASSWORD=minionsbot2024
LAVALINK_HOST=lavalink
LAVALINK_PORT=2333

# ===== Fontes de música (LavaSrc) =====
# Spotify: developer.spotify.com/dashboard -> Create app (grátis). Obrigatório p/ Spotify.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# YouTube OAuth: deixe vazio no 1º boot; veja a URL/código em `docker compose logs lavalink`,
# logue com uma conta Google descartável e cole o refreshToken gerado aqui.
YT_REFRESH_TOKEN=
# PoToken (DESTRAVA o áudio do YouTube). Gere com:
#   docker run --rm ghcr.io/iv-org/youtube-trusted-session-generator
# e cole os dois valores abaixo (visitor_data e po_token).
YT_VISITOR_DATA=
YT_PO_TOKEN=
# Deezer (opcional): full tracks precisam de ARL (conta Deezer grátis). Sem ARL = preview.
DEEZER_ENABLED=false
DEEZER_ARL=
DEEZER_MASTER_KEY=g4el58wc0zvf9na1
# Apple Music (opcional): JWT media token (music.apple.com via DevTools). Expira.
APPLEMUSIC_ENABLED=false
APPLEMUSIC_TOKEN=

# ===== Download (cobalt + yt-dlp) =====
COBALT_BASE_URL=http://cobalt:9000/
COBALT_API_KEY=
MAX_UPLOAD_MB=10
CACHE_TTL_MINUTES=15

# ===== Segredos do bot (opcional: sobrescrevem o config.js) =====
# Recomendado mover pra cá e tirar do config.js (que está versionado).
token=
clientId=
clientSecret=
MONGO_URI=
OPENROUTER_KEY=
ODDS_API_KEY=
STEAM_API_KEY=
LYRICS_API_UID=
LYRICS_API_TOKEN=

# yt-cipher (decifra assinatura do YouTube). Vazio = usa a instância pública.
# Self-host: docker run -d -p 8001:8001 -e API_TOKEN=suasenha <imagem yt-cipher>
YT_CIPHER_URL=https://cipher.kikkia.dev
YT_CIPHER_PASSWORD=
